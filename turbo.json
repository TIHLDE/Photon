{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".next/**", "!.next/cache/**"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "dev": {
            "dependsOn": ["auth#db:push"],
            "cache": false,
            "persistent": true
        },
        "auth#db:push": {
            "dependsOn": ["docker#dev:up"],
            "cache": false
        },
        "docker#dev:up": {
            "cache": false
        }
    }
}

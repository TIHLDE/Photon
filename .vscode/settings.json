{
    "prettier.enable": false,
    "eslint.enable": false,
    "biome.enabled": false,

    "oxc.enable": true,
    "oxc.fmt.configPath": ".oxfmtrc.json",

    "editor.defaultFormatter": "oxc.oxc-vscode",
    "[json]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "editor.codeActionsOnSave": {
        "source.fixAll.oxc": "explicit"
    }
}

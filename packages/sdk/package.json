{
    "name": "@tihlde/sdk",
    "version": "0.0.5",
    "description": "TypeScript SDK for the Photon API",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/TIHLDE/Photon"
    },
    "files": [
        "dist",
        "src/**/*"
    ],
    "type": "module",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": "./src/index.ts",
        "./types": "./src/types.ts",
        "./*": "./*"
    },
    "publishConfig": {
        "access": "public",
        "exports": {
            ".": "./dist/index.mjs",
            "./types": "./dist/types.mjs",
            "./*": "./*"
        },
        "provenance": true
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "codegen": "bun scripts/generate-openapi.ts",
        "typecheck": "tsc --noEmit",
        "postinstall": "node scripts/postinstall.mjs"
    },
    "dependencies": {
        "@photon/api": "workspace:*"
    },
    "devDependencies": {
        "@photon/auth": "workspace:*",
        "@photon/tsconfig": "workspace:*",
        "@types/bun": "catalog:",
        "@types/node": "catalog:",
        "openapi-typescript": "^7.13.0",
        "tsdown": "^0.21.2",
        "typescript": "catalog:"
    }
}

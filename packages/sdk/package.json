{
  "name": "@tihlde/sdk",
  "version": "0.0.5",
  "description": "TypeScript SDK for the Photon API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TIHLDE/Photon"
  },
  "files": [
    "dist",
    "src/**/*"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth.ts",
    "./types": "./src/types/index.ts",
    "./types/auth": "./src/types/auth.ts",
    "./*": "./*"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/index.mjs",
      "./auth": "./dist/auth.mjs",
      "./types": "./dist/types/index.mjs",
      "./types/auth": "./dist/types/auth.mjs",
      "./*": "./*"
    },
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "codegen": "bun scripts/generate-openapi.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@photon/auth": "workspace:*",
    "@photon/tsconfig": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "better-auth": "catalog:",
    "openapi-typescript": "^7.13.0",
    "tsdown": "^0.21.2",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "better-auth": "^1.x.x"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": true
    }
  },
  "inlinedDependencies": {
    "drizzle-orm": "0.44.7"
  }
}

{
    "name": "@tihlde/sdk",
    "version": "0.0.4",
    "description": "TypeScript SDK for the Photon API",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./types": {
            "types": "./dist/types.d.ts",
            "default": "./dist/types.js"
        },
        "./auth": {
            "types": "./dist/auth.d.ts",
            "default": "./dist/auth.js"
        }
    },
    "files": [
        "dist",
        "scripts"
    ],
    "scripts": {
        "build": "bun build.ts",
        "codegen": "bun scripts/generate-openapi.ts",
        "typecheck": "tsc --noEmit",
        "postinstall": "node scripts/postinstall.mjs"
    },
    "dependencies": {
        "openapi-fetch": "^0.17.0"
    },
    "devDependencies": {
        "@photon/auth": "workspace:*",
        "@photon/tsconfig": "workspace:*",
        "@types/bun": "catalog:",
        "@types/node": "catalog:",
        "better-auth": "catalog:",
        "openapi-typescript": "^7.13.0",
        "typescript": "catalog:"
    },
    "peerDependencies": {
        "better-auth": "^1.4.0"
    },
    "peerDependenciesMeta": {
        "better-auth": {
            "optional": true
        }
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/TIHLDE/Photon"
    }
}

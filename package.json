{
    "name": "photon",
    "private": true,
    "workspaces": {
        "packages": [
            "apps/*",
            "packages/*",
            "infra/*"
        ],
        "catalog": {
            "typescript": "^5.9.2",
            "zod": "^4.1.5",
            "@types/bun": "^1.3.9",
            "@types/node": "^24.3.1",
            "oxfmt": "^0.40.0",
            "oxlint": "^1.55.0"
        },
        "catalogs": {
            "testing": {
                "vitest": "^3.2.4"
            },
            "backend": {
                "pg": "^8.18.0",
                "@types/pg": "^8.16.0",
                "bullmq": "^5.70.1",
                "hono": "^4.11.7",
                "drizzle-orm": "^0.44.5",
                "drizzle-seed": "^0.3.1",
                "drizzle-kit": "^0.31.4",
                "better-auth": "^1.6.9",
                "@better-auth/oauth-provider": "^1.6.9"
            },
            "frontend": {
                "react": "^19.2.4",
                "react-dom": "^19.2.4",
                "@types/react": "^19.2.14",
                "@types/react-dom": "^19.2.3",
                "@tailwindcss/vite": "^4.1.18",
                "@tailwindcss/typography": "^0.5.19",
                "tw-animate-css": "^1.3.6",
                "tailwind-merge": "^3.0.2",
                "clsx": "^2.1.1",
                "class-variance-authority": "^0.7.1",
                "tailwindcss": "^4.1.18"
            }
        }
    },
    "type": "module",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "start": "turbo start",
        "test": "turbo test",
        "typecheck": "turbo typecheck",
        "lint": "oxlint .",
        "lint:fix": "oxlint --fix .",
        "format": "oxfmt --check",
        "format:fix": "oxfmt .",
        "db:push": "turbo db:push",
        "db:generate": "turbo db:generate",
        "db:migrate": "turbo db:migrate",
        "db:studio": "turbo db:studio",
        "email": "turbo email",
        "docker:dev": "turbo dev:up --filter=@photon/docker",
        "docker:dev:down": "turbo dev:down --filter=@photon/docker",
        "docker:fresh": "turbo dev:fresh --filter=@photon/docker",
        "docker:prod": "turbo prod:up --filter=@photon/docker",
        "docker:prod:down": "turbo prod:down --filter=@photon/docker",
        "sdk:generate": "turbo codegen --filter=@tihlde/sdk",
        "sdk:update": "turbo build --filter=@tihlde/sdk && changeset",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "turbo build --filter=@tihlde/sdk && changeset publish"
    },
    "devDependencies": {
        "@changesets/changelog-github": "^0.5.2",
        "@changesets/cli": "^2.29.8",
        "@tihlde/sdk": "workspace:*",
        "oxfmt": "catalog:",
        "oxlint": "catalog:",
        "ts-morph": "^27.0.2",
        "turbo": "^2.5.0",
        "typescript": "catalog:"
    },
    "packageManager": "bun@1.3.9"
}
